# ──────────────────────────────────────────────────────────────────────────────
# Petrobalt Agent — переменные окружения
# Скопируйте этот файл в backend/.env для локальной разработки.
# В Railway задайте эти переменные в разделе Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Проект: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# asyncpg direct connection для SQLAlchemy/Alembic
# Supabase → Settings → Database → Connection string (URI) → выберите asyncpg
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── AI / Search ───────────────────────────────────────────────────────────────
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# https://app.tavily.com/home
TAVILY_API_KEY=tvly-...

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=замените-на-случайную-строку-минимум-32-символа

# CORS: через запятую, без пробелов
# Укажите URL вашего фронтенда (Vercel, Railway static, кастомный домен)
ALLOWED_ORIGINS=https://petrobalt.vercel.app,https://your-custom-domain.com

# ── Supabase Storage buckets ──────────────────────────────────────────────────
# Создайте эти buckets в Supabase → Storage
STORAGE_BUCKET_MK=mk-files
STORAGE_BUCKET_DRAWINGS=drawings
STORAGE_BUCKET_QUOTES=quote-attachments
